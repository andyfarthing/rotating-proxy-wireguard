# WireGuard configuration file example
#
# Place one or more .conf files in this directory. Each file represents a
# WireGuard peer that will be added to the proxy pool.
#
# Files must end in .conf and follow the standard WireGuard configuration
# format shown below. These are typically exported directly from your VPN
# provider (e.g. Windscribe, Mullvad, ProtonVPN).
#
# Rename this file to something like:
#   Provider-Location-Server-WG.conf
# and fill in the values for your specific server/account.

[Interface]
# Your WireGuard private key (generated by your VPN provider)
PrivateKey = <your-private-key>

# The IP address assigned to this WireGuard interface
Address = <assigned-ip>/32

# DNS server provided by your VPN provider
DNS = <dns-server-ip>

[Peer]
# The VPN server's public key
PublicKey = <server-public-key>

# Route all traffic through the VPN tunnel
AllowedIPs = 0.0.0.0/0, ::/0

# The VPN server's hostname/IP and port
Endpoint = <server-hostname>:<port>

# Optional: preshared key for an extra layer of security
PresharedKey = <preshared-key>
